# Streamlit Community Cloud の Secrets に貼り付けるフォーマット例
# 「Manage app」→「Settings」→「Secrets」エディタに、この内容をそのままTOMLとして貼り付ける
# [[accounts]] ブロックを繰り返すと複数のIGアカウントを登録できる

# Apify API トークン（Apify Console → Settings → Integrations → API tokens で取得）
APIFY_TOKEN = "apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# IG アカウント（sessionid 方式 / ブラウザCookieのsessionidを貼る）
[[accounts]]
name = "DMO"
username = "instagramユーザー名"
sessionid = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# [[accounts]]
# name = "クライアントB"
# username = "ig_account_b"
# sessionid = "yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy"
